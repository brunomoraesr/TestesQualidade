# ── API ────────────────────────────────────────────────
PETSTORE_BASE_URL=https://petstore.swagger.io/v2

# ── Web ────────────────────────────────────────────────
SAUCEDEMO_BASE_URL=https://www.saucedemo.com
SAUCEDEMO_USER=standard_user
SAUCEDEMO_PASSWORD=secret_sauce

# ── Selenium ───────────────────────────────────────────
# Navegadores suportados: chrome | firefox
BROWSER=chrome
# true = executa sem janela (CI/CD); false = abre o browser
HEADLESS=false
# Tempo máximo (segundos) que o Selenium aguarda por elementos
IMPLICIT_WAIT=10
